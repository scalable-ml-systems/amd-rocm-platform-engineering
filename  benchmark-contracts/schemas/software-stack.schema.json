{
  "$defs": {
    "ExecutionEngine": {
      "description": "Primary framework or runtime being evaluated.",
      "enum": [
        "hip",
        "pytorch",
        "rccl",
        "vllm",
        "sglang"
      ],
      "title": "ExecutionEngine",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Software versions needed to reproduce an experiment.",
  "properties": {
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "software_stack_id": {
      "title": "Software Stack Id",
      "type": "string"
    },
    "operating_system": {
      "minLength": 2,
      "title": "Operating System",
      "type": "string"
    },
    "linux_kernel": {
      "minLength": 2,
      "title": "Linux Kernel",
      "type": "string"
    },
    "amdgpu_driver": {
      "minLength": 1,
      "title": "Amdgpu Driver",
      "type": "string"
    },
    "rocm_version": {
      "minLength": 1,
      "title": "Rocm Version",
      "type": "string"
    },
    "python_version": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Python Version"
    },
    "pytorch_version": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Pytorch Version"
    },
    "container_image": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Container Image"
    },
    "container_image_digest": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Container Image Digest"
    },
    "execution_engine": {
      "$ref": "#/$defs/ExecutionEngine"
    },
    "execution_engine_version": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Execution Engine Version"
    },
    "rccl_version": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Rccl Version"
    },
    "triton_version": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Triton Version"
    },
    "aiter_version": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Aiter Version"
    },
    "atom_version": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Atom Version"
    }
  },
  "required": [
    "software_stack_id",
    "operating_system",
    "linux_kernel",
    "amdgpu_driver",
    "rocm_version",
    "execution_engine"
  ],
  "title": "SoftwareStack",
  "type": "object"
}
